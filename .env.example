# Variáveis obrigatórias na Vercel (Settings → Environment Variables)
# Marque: Production, Preview e Development
# Depois: Deployments → Redeploy

SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=sua-chave-anon-publica-aqui

# Onde encontrar no Supabase:
# Project Settings → API → Project URL  (SUPABASE_URL)
# Project Settings → API → anon public  (SUPABASE_ANON_KEY)
